{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "gleam format $CLAUDE_FILE_PATHS",
            "filePatterns": [
              "**/*.gleam"
            ]
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "just check"
          }
        ],
        "filePatterns": [
          "**/birch_ffi.erl",
          "**/birch_ffi.mjs"
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  Remember: FFI changes require updating BOTH birch_ffi.erl AND birch_ffi.mjs'",
            "filePatterns": [
              "**/birch_ffi.erl",
              "**/birch_ffi.mjs"
            ]
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
